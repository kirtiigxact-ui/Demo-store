{% comment %}
  Section: Custom Hero
  Compatible with Shopify OS 2.0 / Dawn theme
{% endcomment %}

{%- style -%}
  .custom-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 450px;
    overflow: hidden;
    text-align: center;
    color: {{ section.settings.text_color }};
  }

  .custom-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .custom-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  .custom-hero__content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 40px 20px;
  }

  .custom-hero__heading {
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    margin: 0 0 24px;
    line-height: 1.15;
    font-weight: 700;
  }

  .custom-hero__btn {
    display: inline-block;
    padding: 14px 36px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.2s ease;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
  }

  .custom-hero__btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 749px) {
    .custom-hero {
      min-height: 350px;
    }

    .custom-hero__content {
      padding: 30px 16px;
    }
  }
{%- endstyle -%}

<section class="custom-hero">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 1920 | image_tag:
      class: 'custom-hero__image',
      loading: 'lazy',
      widths: '375, 750, 1100, 1500, 1920',
      sizes: '100vw'
    }}
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-hero__image' }}
  {%- endif -%}

  <div class="custom-hero__overlay"></div>

  <div class="custom-hero__content">
    {%- if section.settings.heading != blank -%}
      <h2 class="custom-hero__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="custom-hero__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Custom Hero",
  "tag": "section",
  "class": "custom-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}

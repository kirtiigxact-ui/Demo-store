<section class="wine-testimonials" style="
  background: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
  padding: {{ section.settings.padding }}px 20px;
">

  <div class="wt-container">

    {% if section.settings.subtitle != blank %}
      <p class="wt-sub">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="wt-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="wt-grid">
      {% for block in section.blocks %}
        <div class="wt-card" {{ block.shopify_attributes }}>

          {% comment %} <div class="wt-stars" style="color: {{ section.settings.star_color }}">
            {% for i in (1..block.settings.stars) %}
              ★
            {% endfor %}
          </div> {% endcomment %}

          {% if block.settings.heading != blank %}
            <h3>{{ block.settings.heading }}</h3>
          {% endif %}

          <div class="wt-stars" style="color: {{ section.settings.star_color }}">
            {% for i in (1..block.settings.stars) %}
              ★
            {% endfor %}
          </div>
          
          {% if block.settings.text != blank %}
            <p class="wt-text">"{{ block.settings.text }}"</p>
          {% endif %}

          {% if block.settings.name != blank %}
            <span class="wt-name">— {{ block.settings.name }}</span>
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</section>


<style>
.wine-testimonials {
  background:linear-gradient(120deg, #141414,rgb(67, 18, 18), #141414)!important;
  text-align: center;
}

.wt-container {
  max-width: 1200px;
  margin: auto;
}

.wt-sub {
  opacity: .7;
  margin-bottom: 12px;
  text-transform: uppercase;
  color:#AFA975;
  letter-spacing: 2px;
  font-size: 16px;
}

.wt-title {
  font-size: 40px;
  font-weight: 400;
  margin-top:20px;
  margin-bottom: 60px;
  font-family:Baskervvile , serif;
}

.wt-grid {
  display: grid;
  gap: 30px;
  grid-template-columns: repeat(3, 1fr);
}

.wt-card {
  background:#272727;
  padding: 30px;
  text-align: left;
  box-shadow: 0 8px 24px rgba(0,0,0,.4);
}

.wt-stars {
  font-size: 18px;
  margin-bottom: 12px;
}

.wt-card h3 {
  margin-bottom: 16px;
  font-size: 15px;
  background:#61252D;
  padding: 6px 16px;
  border-radius: 20px;
  font-family:Inter , serif;
  font-weight:200;
  width:fit-content;
}

.wt-text {
  margin-bottom: 20px;
  line-height: 1.6;
  font-size: 16px;
  font-family:Inter , serif;
  font-weight:200;
}

.wt-name {
  font-size: 16px;
  opacity: .6;
  colro:#adadad;
}

@media (max-width: 990px) {
  .wt-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .wt-grid {
    grid-template-columns: 1fr;
  }
  .wt-title {
    font-size: 28px;
  }
}
</style>


{% schema %}
{
  "name": "Wine Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "WHAT CUSTOMERS SAY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join 12,000+ Happy Wine Lovers"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default":"#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#facc15"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Section padding",
      "min": 40,
      "max": 160,
      "step": 10,
      "default": 90
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Amazing product"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "This wine exceeded my expectations. Smooth and delicious."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "John Doe"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wine Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
